#!/usr/bin/env bash
# lich-skills pre-commit hook — blocks commits that contain secrets.
#
# Install:
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
# Or run ./scripts/install-hooks.sh once.
#
# Requires gitleaks (https://github.com/gitleaks/gitleaks)
#   brew install gitleaks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CONFIG="${REPO_ROOT}/.gitleaks.toml"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] gitleaks not installed — install with: brew install gitleaks" >&2
  echo "[pre-commit] skipping secret scan (NOT recommended for an open-source repo)." >&2
  exit 0
fi

echo "[pre-commit] running gitleaks on staged changes..."
gitleaks protect \
  --staged \
  --config "${CONFIG}" \
  --redact \
  --verbose \
  --no-banner

echo "[pre-commit] gitleaks clean."
